# HTTP server listen port.
PORT=8080

# Public base URL of this portal. Used to derive OIDC redirect and post-logout URLs.
# Production example: https://account.liteyuki.org
APP_BASE_URL=http://localhost:8080

# Logto OIDC issuer. Must be an absolute URL.
LOGTO_ISSUER=https://auth.liteyuki.org/oidc

# Logto API base URL used by the BFF when proxying Account API requests.
# Defaults to LOGTO_ISSUER without the trailing /oidc when omitted.
LOGTO_API_BASE_URL=https://auth.liteyuki.org

# Logto prebuilt Account Center base URL.
# Defaults to LOGTO_API_BASE_URL + /account.
LOGTO_ACCOUNT_BASE_URL=https://auth.liteyuki.org/account

# Logto application credentials for the portal OIDC client.
# Required for real login. Leave empty only when PORTAL_DEV_AUTH=true locally.
LOGTO_CLIENT_ID=
LOGTO_CLIENT_SECRET=

# Logto Machine-to-Machine application credentials for Management API.
# Required for profile updates through PATCH /api/users/{sub}.
LOGTO_MANAGEMENT_CLIENT_ID=
LOGTO_MANAGEMENT_CLIENT_SECRET=

# Management API resource indicator.
# Logto Cloud usually uses: https://<tenant-id>.logto.app/api
# Logto OSS default is: https://default.logto.app/api
LOGTO_MANAGEMENT_API_RESOURCE=https://default.logto.app/api

# Scope requested by the M2M client. The M2M role must include Management API permission.
LOGTO_MANAGEMENT_API_SCOPE=all

# HttpOnly portal session cookie name.
SESSION_COOKIE_NAME=yp_session

# Whether the portal session cookie requires HTTPS.
# Defaults to true when APP_BASE_URL starts with https://, otherwise false.
COOKIE_SECURE=false

# Static no-database configuration files.
APP_CATALOG_PATH=configs/app-catalog.yaml
ANNOUNCEMENTS_PATH=configs/announcements.yaml
PORTAL_REQUESTS_PATH=data/requests.json

# Support address shown in the help page and /api/support-info.
SUPPORT_EMAIL=contact@liteyuki.org

# Local development-only login bypass.
# Never enable in production.
PORTAL_DEV_AUTH=false
